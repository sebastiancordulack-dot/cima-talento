{
  "name": "cima-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:hub": "turbo run dev --filter=@cima/hub",
    "dev:portal": "turbo run dev --filter=@cima/portal",
    "build:hub": "turbo run build --filter=@cima/hub",
    "build:portal": "turbo run build --filter=@cima/portal"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
