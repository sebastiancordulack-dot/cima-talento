# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (Step 3)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Cima Talento <talento@cimasales.com>"

# Calendly (Step 8)
CALENDLY_HM_LINK=
CALENDLY_JULIA_LINK=
# From the Calendly webhook subscription (Step 8). Empty until created.
CALENDLY_WEBHOOK_SIGNING_KEY=

# Jotform webhook — generate a random token (openssl rand -hex 24) and append it
# to the webhook URL: /api/webhooks/jotform?token=<token>
JOTFORM_WEBHOOK_TOKEN=
JOTFORM_FORM_ID=261605489959071

# ---- CiMA Activaciones ----
# Sender for the §11 nudge emails (defaults to this exact value if unset).
RESEND_ACTIVACIONES_FROM_EMAIL="CiMA Activaciones <activaciones@cimasales.com>"
# Internal nudge recipients, comma-separated. Empty → all active admin/Julia
# accounts from hiring_managers.
ACTIVACIONES_INTERNAL_EMAILS=
# Client Portal base URL used in client-facing email CTAs. Set this to the
# portal's deployment URL until portal.cimasales.com exists.
NEXT_PUBLIC_PORTAL_URL=
