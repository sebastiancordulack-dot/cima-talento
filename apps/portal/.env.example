# Copy to .env.local and fill in. .env.local is gitignored.
# The Client Portal shares the SAME Supabase instance as CiMA Hub.

# Supabase (same project as Hub)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Only set if the portal needs privileged access. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
