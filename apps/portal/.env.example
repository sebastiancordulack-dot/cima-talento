# Copy to .env.local and fill in. .env.local is gitignored.
# The Client Portal shares the SAME Supabase instance as CiMA Hub.

# Supabase (same project as Hub)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Only set if the portal needs privileged access. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Auth cookie name — distinct per app so hub/portal sessions never mix.
NEXT_PUBLIC_SUPABASE_COOKIE_NAME=sb-cima-portal
# Emails sent by the submit action (Resend) — same values as the Hub.
RESEND_API_KEY=
ACTIVACIONES_INTERNAL_EMAILS=
